module Test.Compiler.Parse.Space exposing ( tests )

import Expect exposing (Expectation)
import Test exposing (Test, describe, test)
import String.Parser.Advanced as Parser exposing (Parser)
import Compiler.Parse.Space as PS
import Compiler.Parse.Context as Context exposing (Context)
import Dict


tests : Test
tests =
    describe "Parse.Space"
        [ describe "parser"
            [ test "parses spaces" <| \_ ->
                Parser.run PS.parser Context.empty "   "
                    |> Expect.equal (Ok {})
            , test "parses newlines" <| \_ ->
                Parser.run PS.parser Context.empty "\n"
                    |> Expect.equal (Ok {})
            , test "parses mixed whitespace" <| \_ ->
                Parser.run PS.parser Context.empty " \n \r "
                    |> Expect.equal (Ok {})
            , test "parses empty string" <| \_ ->
                Parser.run PS.parser Context.empty ""
                    |> Expect.equal (Ok {})
            , test "can read from context where the first non-space col began" <| \_ ->
                Parser.run payloadParser Context.empty "a"
                    |> expectLineStart 1
            , test "can read from context where the first non-space col began (indented)" <| \_ ->
                Parser.run payloadParser Context.empty "   a"
                    |> expectLineStart 4
            , test "setIndentToStartOfLine" <| \_ ->
                let
                    setIndentParser =
                        Parser.succeed identity
                            |> Parser.skip PS.parser
                            |> Parser.skip PS.setIndentToStartOfLine
                            |> Parser.keep Parser.getPayload
                in
                Parser.run setIndentParser Context.empty "    b"
                    |> Result.map .indent
                    |> Expect.equal (Ok 5)
            ]
    , describe "comments" <|
        [ test "parses line comments" <| \_ ->
            Parser.run (parseToEnd payloadParser) Context.empty "-- this is a line comment"
                |> expectComment 1 1 (Context.Line "this is a line comment")
        , test "parses line comments even when prefixed with space" <| \_ ->
            Parser.run (parseToEnd payloadParser) Context.empty "  -- this is a line comment"
                |> expectComment 1 3 (Context.Line "this is a line comment")
        , test "block comments" <| \_ ->
            Parser.run (parseToEnd payloadParser) Context.empty "{- this is a block comment -}"
                |> expectComment 1 1 (Context.Block "this is a block comment")
        ]
    , describe "checkIndent" <|
        let
            indentParser =
                Parser.succeed {}
                    |> Parser.skip PS.parser
                    |> Parser.mapError (\_ -> {})
                    |> Parser.andThen (\_ -> PS.checkIndent)
        in    
        [ test "succeeds when column is greater than indent" <| \_ ->
            let
                context =
                    { Context.empty | indent = 2 }
            in
            Parser.run indentParser context "  x"
                |> Expect.equal (Ok {})
        , test "fails when column is less than indent" <| \_ ->
            let
                context =
                    { Context.empty | indent = 4 }
            in
            Parser.run indentParser context "  x"
                |> expectProblem
        , test "fails when column is 1" <| \_ ->
            let
                context =
                    { Context.empty | indent = 1 }
            in
            Parser.run indentParser context "x"
                |> expectProblem
        ]
    ]


expectProblem : Result x y -> Expectation
expectProblem result =
    when result is
        Ok _ ->
            Expect.fail "Expected parser to fail but it succeeded"
        Err _ ->
            Expect.pass


payloadParser : Parser Context PS.Error Context
payloadParser =
    Parser.succeed identity
        |> Parser.skip PS.parser
        |> Parser.keep Parser.getPayload


parseToEnd : Parser Context PS.Error a -> Parser Context PS.Error a
parseToEnd p =
    Parser.skip (Parser.end PS.InvalidWhiteSpace) p


expectComment : Int -> Int -> Context.CommentValue -> Result x Context -> Expectation
expectComment row col comment resultContext =
    when resultContext is
        Err err ->
            Expect.fail ("Failed to parse with error: " ++ Debug.toString err)

        Ok ctx ->
            when Dict.get row ctx.comments is
                Nothing ->
                    Expect.fail "Parsed successfully without comments"

                Just commentsOnRow ->
                    Expect.equal
                        [ { row = row
                          , col = col
                          , value = comment
                          }
                        ]
                        commentsOnRow


expectLineStart : Int -> Result x Context -> Expectation
expectLineStart col resultContext =
    when resultContext is
        Err err ->
            Expect.fail ("Failed to parse with error: " ++ Debug.toString err)

        Ok ctx ->
            Expect.equal col ctx.lineStart
